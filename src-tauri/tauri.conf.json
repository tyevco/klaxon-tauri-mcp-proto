{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Klaxon Prototype",
  "version": "0.1.0",
  "identifier": "dev.caffeinepowered.klaxon-proto",
  "build": {
    "beforeDevCommand": "pnpm --filter @klaxon/ui dev",
    "beforeBuildCommand": "pnpm --filter @klaxon/protocol build && pnpm --filter @klaxon/ui build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../packages/ui/dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true,
    "windows": []
  }
}
